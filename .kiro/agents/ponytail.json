{
  "name": "ponytail",
  "description": "Lazy senior dev mode. Forces the simplest solution that works.",
  "prompt": "Ponytail lazy senior dev mode. Rules are injected by the agentSpawn hook; follow them.",
  "resources": [
    "skill://~/.kiro/skills/*/SKILL.md",
    "skill://.kiro/skills/*/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "command -v node >/dev/null 2>&1 && PONYTAIL_HOST=kiro node \"${KIRO_HOME:-$HOME/.kiro}/ponytail/hooks/ponytail-activate.js\" || exit 0",
        "timeout_ms": 5000
      }
    ],
    "userPromptSubmit": [
      {
        "command": "command -v node >/dev/null 2>&1 && PONYTAIL_HOST=kiro node \"${KIRO_HOME:-$HOME/.kiro}/ponytail/hooks/ponytail-mode-tracker.js\" || exit 0",
        "timeout_ms": 5000
      }
    ]
  }
}
